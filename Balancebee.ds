	 			row = 1
	 			column = 1   
				width = medium
			)
			created_date
			(
    			type = datetime
				displayname = "Created Date"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Budget Created","Budget Reviewed","Budget Rejected","Budget Approved","Budget Revised","Budget in Progress","Budget Over Budget","Budget On Track","Budget Closed"}
			}
		}
