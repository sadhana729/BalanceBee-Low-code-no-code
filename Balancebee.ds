		form expenses
		{
			displayname = "Expenses"
			success message = "Expense Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			expense_id
			(
    			type = autonumber
				displayname = "Expense ID"
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			expense_title
			(
    			type = text
				displayname = "Expense Title"
	 			row = 1
	 			column = 1   
				width = medium
			)
			category
			(
				type = picklist
				displayname = "Category"
				values = {"EMI","Travel","Entertainment","Health","Shopping","Food","Bills","Other"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			amount
			(
				displayname = "Amount"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			payment_type
			(
				type = radiobuttons
				displayname = "Payment Type"
				values = {"Account","Cash"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			expense_date
			(
    			type = date
				displayname = "Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			notes
			(
    			type = textarea
				displayname = "Notes"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			is_shared
			(
    			type = checkbox
				displayname = "Is Shared with Friend"
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
			friend_name
			(
    			type = text
				displayname = "Friend Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			friend_contact
			(
    			type = text
				displayname = "Friend Contact"
	 			row = 1
	 			column = 1   
				width = medium
			)
			amount_to_collect
			(
				displayname = "Amount to Collect from Friend"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = radiobuttons
				displayname = "Status"
				values = {"Pending from Friend","Paid"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			user
			(
				type = list	
				displayname = "User"
				values  = users.ID
    			displayformat = [user_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Expense Created","Expense Verified","Expense Pending Approval","Expense Cancelled","Expense Rejected","Expense Approved","Expense Updated","Amount to Collect Set","Collection Request Sent","Expense Settled","Collection Confirmed","Collection Follow-Up","Collection Overdue","Collection Escalated","Expense Closed"}
			}
		}
