 application "copy of Balance Management System"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"
 	forms
	{
		form balance_records
		{
			displayname = "Balance Records"
			success message = "Balance Record Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			cash_balance
			(
				displayname = "Current Cash Balance"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			account_balance
			(
				displayname = "Current Account Balance"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			total_balance
			(
				displayname = "Total Balance"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			transaction_date
			(
    			type = date
				displayname = "Transaction Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			user
			(
				type = list	
				displayname = "User"
				values  = users.ID
    			displayformat = [user_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
