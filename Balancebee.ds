	reports
	{
		list friend_reminders_Report
		{
			displayName = "All Friend Reminders"
			show all rows from friend_reminders    
			(
				friend_name as "Friend Name"
				friend_contact as "Friend Contact"
				amount_owed as "Amount Owed"
				(
					display = total,average,min,max	
				)
				expense_title as "Expense Title"
				last_sent as "Last Sent"
				status as "Status"
				user as "User"
				expense as "Expense"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "Completed")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "Not Sent")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (status == "Sent")
				fields = [status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban friend_reminders_by_status
		{
			displayName = "Statuses"
			show all rows from friend_reminders    
			(
				friend_name as "Friend Name"
				friend_contact as "Friend Contact"
				amount_owed as "Amount Owed"
				(
					display = total,average,min,max	
				)
				expense_title as "Expense Title"
				last_sent as "Last Sent"
				status as "Status"
				user as "User"
				expense as "Expense"
			)
			options
			(
	 			display field = status
	 		)
		}
		list expenses_Report
		{
			displayName = "All Expenses"
			show all rows from expenses    
			(
				expense_id as "Expense ID"
				expense_title as "Expense Title"
				category as "Category"
				amount as "Amount"
				(
					display = total,average,min,max	
				)
				payment_type as "Payment Type"
				expense_date as "Date"
				notes as "Notes"
				is_shared as "Is Shared with Friend"
				friend_name as "Friend Name"
				friend_contact as "Friend Contact"
				amount_to_collect as "Amount to Collect from Friend"
				(
					display = total,average,min,max	
				)
				status as "Status"
				user as "User"
